#!/bin/busybox sh
# =============================================================================
# PocketForge initrd /init — TrimUI Smart Pro S (Allwinner A523, owned 5.15.154)
# -----------------------------------------------------------------------------
# Boot-critical. A wrong /init = no boot. The A523 job is simpler than the A133:
#   1. NO GPU module preload — the A523 GPU stack (tsp-vuo.2) is not yet
#      integrated, and the A523 kernel builds MMC + ext4 in-tree, so nothing
#      needs insmod-ing before we can read the rootfs.
#   2. find the rootfs by FILESYSTEM LABEL (POCKETFORGE_DATA) — robust against
#      the mmcblk0/mmcblk1 enumeration race when the eMMC is also present.
#   3. switch_root into the real Debian rootfs (systemd).
#
# Observability mirrors the A133 initrd: every step logs to BOTH ttyAS0 and a
# persistent file on the FAT boot partition, so a failed boot is diagnosable by
# pulling the SD. Logging never blocks boot. On any failure we drop to an
# interactive busybox shell on ttyAS0 rather than hanging silently.
#
# busybox findfs supports ONLY LABEL=/UUID= (no PARTLABEL=), so we resolve by
# the filesystem volume label set at build time:
#   FAT boot  -> label POCKETFORGE        (mkfs.vfat -n)
#   ext4 root -> label POCKETFORGE_DATA   (mke2fs -L)
# =============================================================================

/bin/busybox --install -s /bin

mount -t proc     proc     /proc
mount -t sysfs    sysfs    /sys
mount -t devtmpfs devtmpfs /dev

# --- on-SD boot log (FAT boot partition, label POCKETFORGE) -------------------
PFLOG=""
mkdir -p /pflog
LOGDEV="$(findfs LABEL=POCKETFORGE 2>/dev/null)"
if [ -n "$LOGDEV" ] && mount -t vfat -o rw,flush "$LOGDEV" /pflog 2>/dev/null; then
    PFLOG=/pflog/bootlog.txt
    : > "$PFLOG" 2>/dev/null || PFLOG=""
fi

log() {
    echo "[pf-initrd] $*"
    if [ -n "$PFLOG" ]; then
        echo "[pf-initrd] $*" >> "$PFLOG" 2>/dev/null
        sync 2>/dev/null
    fi
}

fail() {
    log "FAILURE: $*"
    log "dropping to busybox shell (console=ttyAS0,115200)"
    sync 2>/dev/null
    exec /bin/sh
}

PF_INITRD_VERSION="$(cat /etc/pocketforge-initrd-version 2>/dev/null || echo dev)"
log "STAGE: banner — PocketForge A523 initrd ${PF_INITRD_VERSION} booting"
log "STAGE: kver $(cat /proc/version 2>/dev/null)"
log "STAGE: model $(cat /proc/device-tree/model 2>/dev/null)"
if [ -n "$PFLOG" ]; then
    log "STAGE: on-SD log active at boot:/bootlog.txt ($LOGDEV)"
else
    log "STAGE: on-SD log UNAVAILABLE (boot FAT not mountable) — console only"
fi

# =============================================================================
# SELF-FLASH RECOVERY  (dev images only; bd tsp-bcx.18 — A523 port of tsp-bcx.17)
# -----------------------------------------------------------------------------
# In-place whole-image self-flash for swap-free dev iteration. A host pushes a
# compressed image (.img.xz) to a RAW staging region in the UNALLOCATED TAIL of
# the SD (past the image), then writes a 512-byte flag record to a trailing
# sector and reboots. This branch — running from the RAM initramfs with the SD
# UNMOUNTED — reads the staged blob from the high region and writes the
# decompressed whole image to [0,img) of the SAME unmounted SD, SHA-verifies,
# then reboots onto the new image. NO network, NO RAM staging, NOTHING from the
# SD mounted during the dd. Power-safe (state=armed until verified; idempotent
# dd; tries cap). No hard-coded offsets (host computes; /init reads the flag).
# Gated on /etc/pocketforge-selfflash (DEV initrds only).
#
# A523 deltas vs the A133 (tsp-bcx.17): the SD is /dev/mmcblk1 and the eMMC is
# /dev/mmcblk0 (a populated, bootable vendor OS = the FEL fallback). findfs keys
# on the POCKETFORGE_DATA label which only exists on the SD, so it resolves to
# mmcblk1 — but we ALSO hard-guard against ever targeting mmcblk0.
# =============================================================================
SF_BS=4194304          # 4 MiB transfer block
SF_ALIGN_SECT=8192     # 4 MiB in 512-byte sectors (stage_lba alignment)

selfflash_write_flag() {
    sf_st="$1"; sf_tr="$2"; sf_sl="$3"; sf_xb="$4"; sf_xs="$5"
    sf_ib="$6"; sf_is="$7"; sf_cs="$8"; sf_sd="$9"; sf_fl="${10}"
    {
        printf 'PF_FLAG=1\n'; printf 'ver=1\n'
        printf 'state=%s\n'        "$sf_st"
        printf 'stage_lba=%s\n'    "$sf_sl"
        printf 'xz_bytes=%s\n'     "$sf_xb"
        printf 'xz_sha256=%s\n'    "$sf_xs"
        printf 'img_bytes=%s\n'    "$sf_ib"
        printf 'img_sha256=%s\n'   "$sf_is"
        printf 'tries=%s\n'        "$sf_tr"
        printf 'card_sectors=%s\n' "$sf_cs"
    } > /sf-flag.txt
    dd if=/dev/zero of=/sf-flag.bin bs=512 count=1 2>/dev/null
    dd if=/sf-flag.txt of=/sf-flag.bin conv=notrunc 2>/dev/null
    dd if=/sf-flag.bin of="$sf_sd" bs=512 seek="$sf_fl" count=1 2>/dev/null
    sync
}

# A recovery-write failure handler. Once the destructive dd has begun (SF_WRITING=1),
# the rootfs [0,img) is presumed PARTIALLY WRITTEN — we must NEVER fall through to the
# normal-boot mount path (that mounts a corrupt rootfs -> fail() -> dead-end shell, the
# observed "device inoperable" brick). Instead reboot to retry recovery; the flag stays
# in the writing state with tries bounded, so retries converge to either a clean flash
# or the tries>=3 halt-in-recovery branch. Before any write (rootfs still intact) it is
# safe to return 1 and let the caller continue a NORMAL boot.
sf_fail_retry() {
    log "selfflash: $1"
    if [ "$SF_WRITING" = 1 ]; then
        log "selfflash: a destructive write had begun — rebooting to RETRY recovery (refusing to boot a possibly half-written rootfs)"
        sync
        # reboot -f should never return. If it DOES (or is too slow), we must NEVER
        # fall through to `return 1` -> the caller's normal-boot mount path, which
        # would boot the half-written rootfs (the exact brick this guards against).
        # So re-issue reboot forever: this infinite loop IS the non-returning
        # guarantee (control cannot leave it), so no code after it is reachable.
        while :; do
            reboot -f
            sleep 5
        done
    fi
    return 1
}

selfflash_recover() {
    SD="$1"; NSECT="$2"; FLAG_LBA="$3"; FLAGTXT="$4"
    SF_WRITING=0
    # SAFETY: the target SD is resolved by the rootfs LABEL (POCKETFORGE_DATA),
    # which exists ONLY on our SD — never the eMMC's vendor OS — so the eMMC can
    # never be selected regardless of enumeration. NOTE: on this owned kernel the
    # SD enumerates as mmcblk0 (sdc0@4020000 probes before the eMMC sdc2@4022000),
    # i.e. the OPPOSITE of the kickoff-doc assumption — so do NOT device-number-
    # guard on mmcblk0 (that would refuse the real SD). The label is the guard.
    fget() { printf '%s\n' "$FLAGTXT" | sed -n "s/^$1=//p" | head -1; }
    state="$(fget state)";        stage_lba="$(fget stage_lba)"
    xz_bytes="$(fget xz_bytes)";  xz_sha="$(fget xz_sha256)"
    img_bytes="$(fget img_bytes)"; img_sha="$(fget img_sha256)"
    tries="$(fget tries)";        flag_card="$(fget card_sectors)"
    [ -n "$tries" ] || tries=0

    # Enter recovery for BOTH armed (freshly pushed) and writing (a destructive
    # write began on a prior boot and was interrupted — must finish, never normal-
    # boot the half-written rootfs). Any other state (done/failed/unknown) -> normal.
    case "$state" in
        armed)   ;;
        writing) SF_WRITING=1 ;;   # a prior attempt already started writing -> rootfs presumed corrupt
        *) log "selfflash: state=$state (not armed) — normal boot"; return 1;;
    esac
    log "selfflash: ENTER state=$state stage_lba=$stage_lba xz_bytes=$xz_bytes img_bytes=$img_bytes tries=$tries"

    for v in "$stage_lba" "$xz_bytes" "$img_bytes"; do
        case "$v" in ''|*[!0-9]*) log "selfflash: bad numeric field — abort to normal boot"; return 1;; esac
    done
    [ "$flag_card" = "$NSECT" ] || log "selfflash: WARN card_sectors flag=$flag_card live=$NSECT"

    xz_sectors=$(( (xz_bytes + 511) / 512 ))
    img_sectors=$(( (img_bytes + 511) / 512 ))
    [ $((stage_lba + xz_sectors)) -lt "$NSECT" ] || { log "selfflash: staged blob past card end — abort"; return 1; }
    [ "$stage_lba" -gt "$img_sectors" ]          || { log "selfflash: staged blob overlaps image region — abort"; return 1; }
    [ $(( stage_lba % SF_ALIGN_SECT )) -eq 0 ]   || { log "selfflash: stage_lba not 4MiB-aligned — abort"; return 1; }
    skip4m=$(( stage_lba / SF_ALIGN_SECT ))

    if [ "$tries" -ge 3 ]; then
        log "selfflash: tries=$tries >= 3 — giving up"
        if [ "$SF_WRITING" = 1 ]; then
            # A destructive write began on an earlier attempt -> the rootfs is
            # partially written. Do NOT fall through to mount it, and — critically —
            # do NOT downgrade the on-disk flag from `writing` to `failed`: `failed`
            # hits the case "*" default on the NEXT power-cycle and would normal-boot
            # the corrupt rootfs (the exact brick). KEEP state=writing so every
            # subsequent boot re-enters recovery via the `writing` case and halts
            # here again — the rootfs can never be normal-booted. tries stays >=3
            # (the flag is only re-armed on the pre-write success path below), so
            # this converges to a stable halt, not an ever-growing retry count.
            fail "selfflash: retries exhausted AFTER a destructive write began — rootfs is partially written and must NOT be booted. On-disk flag stays state=writing so future boots re-enter recovery (never normal-boot). Reflash via Dell: flash-owned-image.sh --target dell --slot pros. Halting in recovery."
        fi
        # No destructive write ever began -> the rootfs is fully intact. Record the
        # terminal `failed` state (so future boots take the normal-boot default) and
        # continue a normal boot. Safe: state=failed only ever normal-boots a rootfs
        # that was never written.
        selfflash_write_flag failed "$tries" "$stage_lba" "$xz_bytes" "$xz_sha" "$img_bytes" "$img_sha" "$NSECT" "$SD" "$FLAG_LBA"
        log "selfflash: retries exhausted but NO destructive write had begun (rootfs intact) — normal boot"
        return 1
    fi
    # Re-arm before attempting. Preserve the writing state once a destructive write
    # has begun (across interrupted reboots) so the rootfs is never assumed intact.
    sf_rearm=armed
    [ "$SF_WRITING" = 1 ] && sf_rearm=writing
    selfflash_write_flag "$sf_rearm" "$((tries+1))" "$stage_lba" "$xz_bytes" "$xz_sha" "$img_bytes" "$img_sha" "$NSECT" "$SD" "$FLAG_LBA"
    tries=$((tries + 1))

    if [ -n "$PFLOG" ]; then sync; umount /pflog 2>/dev/null; PFLOG=""; fi
    if mount | grep -q mmcblk; then
        log "selfflash: FATAL — mmcblk still mounted, refusing to flash:"
        mount | grep mmcblk | while read -r l; do log "  $l"; done
        fail "selfflash: SD still mounted before dd"
    fi
    log "selfflash: SD unmounted; verified no mmcblk mounts"

    log "selfflash: verifying staged .img.xz sha256..."
    got_xz="$(dd if="$SD" bs="$SF_BS" skip="$skip4m" 2>/dev/null | head -c "$xz_bytes" | sha256sum | cut -d' ' -f1)"
    if [ "$got_xz" != "$xz_sha" ]; then
        # Pre-write check: rootfs still intact unless a prior interrupted attempt
        # already wrote (SF_WRITING). sf_fail_retry routes correctly for both.
        sf_fail_retry "staged .xz SHA MISMATCH (got $got_xz want $xz_sha) — staged blob bad/incomplete"
        return 1
    fi
    log "selfflash: staged .xz verified OK"

    # POINT OF NO RETURN. Commit state=writing to the flag BEFORE touching [0,img):
    # if power is lost mid-dd, the next boot reads state=writing and re-enters
    # recovery (never normal-boots the half-written rootfs). The "valid image"
    # marker (state=done) is written LAST, only after a full read-back SHA verify.
    #
    # The point-of-no-return guarantee depends ENTIRELY on this flag being durably
    # persisted: if the flag-sector write silently fails (dd errors are swallowed),
    # the next boot would read the STALE state and normal-boot AFTER a partial
    # write. So write it, then READ IT BACK and confirm it reads state=writing
    # before we let THIS boot touch [0,img). If the read-back does not confirm,
    # REFUSE to begin the destructive dd and halt in recovery (never boot):
    #   - fresh arm (state was 'armed'): the rootfs is still fully intact, so
    #     halting is safe and loses nothing.
    #   - re-entry (state was already 'writing' from an interrupted prior boot):
    #     the rootfs may already be partial, so halting (never booting) is exactly
    #     what we must do.
    # Either way, halt-not-boot is correct. Do NOT set SF_WRITING for THIS boot
    # until the flag is verified persisted (in the fresh-arm case that keeps the
    # halt pre-destructive; the re-entry case already had SF_WRITING=1 set above).
    selfflash_write_flag writing "$tries" "$stage_lba" "$xz_bytes" "$xz_sha" "$img_bytes" "$img_sha" "$NSECT" "$SD" "$FLAG_LBA"
    sync
    sf_rb="$(dd if="$SD" bs=512 skip="$FLAG_LBA" count=1 2>/dev/null | tr -d '\000' | tr -cd '[:print:]\n')"
    if ! printf '%s\n' "$sf_rb" | grep -q '^state=writing$'; then
        log "selfflash: state=writing flag read-back FAILED (flag sector did not persist) — refusing the destructive write"
        fail "selfflash: could not persist the point-of-no-return flag (state=writing) — NOT beginning the destructive dd. Reflash via Dell if needed: flash-owned-image.sh --target dell --slot pros. Halting in recovery."
    fi
    SF_WRITING=1
    log "selfflash: state=writing committed + read-back verified — destructive write begins (point of no return)"

    log "selfflash: flashing — dd skip=$skip4m | unxz | dd of=$SD ..."
    if ! dd if="$SD" bs="$SF_BS" skip="$skip4m" 2>/dev/null | head -c "$xz_bytes" | unxz | dd of="$SD" bs="$SF_BS" 2>/dev/null; then
        sf_fail_retry "flash pipeline returned error"
        return 1
    fi
    sync
    log "selfflash: write complete; read-back verifying image sha256..."
    got_img="$(dd if="$SD" bs="$SF_BS" 2>/dev/null | head -c "$img_bytes" | sha256sum | cut -d' ' -f1)"
    if [ "$got_img" != "$img_sha" ]; then
        sf_fail_retry "image read-back SHA MISMATCH (got $got_img want $img_sha)"
        return 1
    fi
    log "selfflash: image verified OK — marking done, rebooting into new image"
    selfflash_write_flag done "$tries" "$stage_lba" "$xz_bytes" "$xz_sha" "$img_bytes" "$img_sha" "$NSECT" "$SD" "$FLAG_LBA"
    sync
    reboot -f
    return 0   # not reached
}

# --- self-flash gate (dev images only) ----------------------------------------
if [ -f /etc/pocketforge-selfflash ]; then
    log "STAGE: self-flash gate — waiting for SD enumeration"
    SF_ROOTPART=""; SF_WAIT=0
    while [ "$SF_WAIT" -lt 20 ]; do
        SF_ROOTPART="$(findfs LABEL=POCKETFORGE_DATA 2>/dev/null)"
        [ -n "$SF_ROOTPART" ] && [ -b "$SF_ROOTPART" ] && break
        SF_ROOTPART=""; sleep 1; SF_WAIT=$((SF_WAIT + 1))
    done
    if [ -n "$SF_ROOTPART" ]; then
        log "STAGE: self-flash gate — SD ready after ${SF_WAIT}s ($SF_ROOTPART)"
        # The two mmc controllers (SD sdc0@4020000 + eMMC sdc2@4022000) can still
        # be settling their mmcblkN numbering / final capacity this early in boot
        # (the very-eager "after 0s" probe raced: the flag was armed but read as
        # absent, with the full-OS replay reading it fine). Re-resolve the SD by
        # LABEL and read the flag in a short retry loop; act the instant a valid
        # flag appears. Non-destructive, so retrying is safe. Logs each probe.
        SF_FOUND=0; SF_TRY=0
        while [ "$SF_TRY" -lt 3 ]; do
            SF_ROOTPART="$(findfs LABEL=POCKETFORGE_DATA 2>/dev/null)"
            SF_SD="$(echo "$SF_ROOTPART" | sed 's/p[0-9]*$//')"   # /dev/mmcblk0p2 -> /dev/mmcblk0
            SF_DISK="$(basename "$SF_SD")"
            SF_PART="$(basename "$SF_ROOTPART")"                   # mmcblk0p2
            SF_NSECT="$(cat "/sys/block/${SF_DISK}/size" 2>/dev/null)"
            # Flag + staging live JUST PAST the rootfs partition (low LBA), NOT at
            # the card end: the A523 early-boot MMC does not service the ~62 GB
            # card-end LBA yet (reads return empty), though the full OS does. The
            # region adjacent to the (provably-readable) rootfs partition reads
            # fine. Both the gate and the host pusher derive flag_lba the same way
            # from the partition table: align_up(part_end + 1 MiB, 4 MiB).
            SF_PSTART="$(cat "/sys/class/block/${SF_PART}/start" 2>/dev/null)"
            SF_PSIZE="$(cat "/sys/class/block/${SF_PART}/size" 2>/dev/null)"
            if [ -n "$SF_PSTART" ] && [ -n "$SF_PSIZE" ] && [ -n "$SF_NSECT" ] && [ "$SF_NSECT" -gt 4096 ]; then
                SF_PEND=$(( SF_PSTART + SF_PSIZE ))
                SF_FLAG_LBA=$(( (SF_PEND + 2048 + 8191) / 8192 * 8192 ))
                SF_FLAGTXT="$(dd if="$SF_SD" bs=512 skip="$SF_FLAG_LBA" count=1 2>/dev/null | tr -d '\000' | tr -cd '[:print:]\n')"
                SF_HDR="$(printf '%s' "$SF_FLAGTXT" | head -c 11)"
                log "STAGE: self-flash flag probe try=${SF_TRY} sd=${SF_SD} pend=${SF_PEND} flag_lba=${SF_FLAG_LBA} hdr=[${SF_HDR}]"
                if printf '%s\n' "$SF_FLAGTXT" | grep -q '^PF_FLAG=1'; then
                    SF_FOUND=1
                    log "STAGE: self-flash flag present on ${SF_SD} (sector ${SF_FLAG_LBA})"
                    selfflash_recover "$SF_SD" "$SF_NSECT" "$SF_FLAG_LBA" "$SF_FLAGTXT" \
                        && log "selfflash: recovery returned without reboot — continuing normal boot" \
                        || log "selfflash: not flashing — continuing normal boot"
                    break
                fi
            fi
            SF_TRY=$((SF_TRY + 1)); sleep 2
        done
        [ "$SF_FOUND" = 1 ] || log "STAGE: self-flash gate — no armed flag after settle (${SF_TRY} probes) — normal boot"
    fi
fi

# --- find + mount the rootfs by filesystem LABEL ------------------------------
log "STAGE: locate rootfs by LABEL=POCKETFORGE_DATA"
ROOT=""
# udev/devtmpfs may need a beat to enumerate the second mmc; retry briefly.
i=0
while [ "$i" -lt 20 ]; do
    ROOT="$(findfs LABEL=POCKETFORGE_DATA 2>/dev/null)"
    [ -n "$ROOT" ] && break
    sleep 0.5; i=$((i + 1))
done
[ -n "$ROOT" ] || fail "rootfs not found (LABEL=POCKETFORGE_DATA)"
log "STAGE: rootfs is $ROOT"

mkdir -p /newroot
log "STAGE: mount $ROOT -> /newroot (ext4)"
mount -t ext4 -o rw,noatime "$ROOT" /newroot || fail "mount $ROOT failed"

# --- watchdog ping before handoff (harmless if no /dev/watchdog) --------------
# If the A523 sunxi-wdt auto-armed, reset its counter so systemd has a full
# window to take ownership. '\0' = keepalive ping (NOT 'V' = magic-close/disarm).
if [ -c /dev/watchdog ]; then
    printf '\0' > /dev/watchdog
    log "STAGE: watchdog ping (counter reset for systemd handoff)"
fi

# --- pre-switch_root verification (catch ENOENT-from-exec before the PONR) ----
if [ -n "$PFLOG" ]; then sync 2>/dev/null; umount /pflog 2>/dev/null; fi

INIT=/usr/lib/systemd/systemd
if [ ! -x "/newroot${INIT}" ]; then
    log "WARN: ${INIT} not found, trying /sbin/init"
    INIT=/sbin/init
fi
if [ ! -x "/newroot${INIT}" ]; then
    log "ERROR: no init binary found on rootfs"
    ls -la /newroot/usr/lib/systemd/ 2>&1 | while read -r line; do log "    $line"; done
    fail "init binary not found on rootfs"
fi
if [ ! -f "/newroot/usr/lib/aarch64-linux-gnu/ld-linux-aarch64.so.1" ]; then
    fail "dynamic linker (ld-linux-aarch64.so.1) not found on rootfs"
fi
log "STAGE: switch_root /newroot $INIT"
exec switch_root /newroot "$INIT" || fail "switch_root failed"
