# PocketForge A523 (tsp-s) SD image — committed filesystem identifiers
# Generated once (deterministic uuid5 over the "pocketforge-os.tsp-s.a523"
# namespace; see boards/tsp-s/README.md). All builds use these so the image is
# reproducible. Changing any value here changes the image SHA-256.
#
# Used by: boards/tsp-s/assemble-sd.sh, scripts/build-rootfs-a523.sh
# Gate: G-reproducible (re-targeted from the A133 G-reproducible work)

# ext4 rootfs partition (the Debian rootfs; switch_root finds it by LABEL).
USERDATA_FS_UUID=ea29eabf-9a97-5240-8346-bc12f9e16866
USERDATA_HASH_SEED=937556f6-463c-50ad-82bc-1ff66edd7855

# FAT32 boot partition — 32-bit volume serial (mkfs.vfat -i, no dash).
BOOTRES_VOLID=45B2A2B9

# MBR disk signature (sfdisk `label-id`) — gives stable PARTUUIDs too.
MBR_DISK_SIG=0x96b2b326
