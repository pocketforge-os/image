# =============================================================================
# boards/tsp-s/board.env — TrimUI Smart Pro S (A523 / sun55iw3 / TG5050)
# =============================================================================
# Board metadata for the SoC-agnostic image pipeline, re-targeted to the A523
# (bead tsp-vuo.4). Mirrors the role of the hardcoded values in the A133 `tsp`
# board, but the A523 boots a fundamentally different chain: mainline U-Boot
# v2025.10 (SPL+U-Boot raw at 8 KiB) + extlinux/distro-boot from a FAT
# partition, NOT the vendor boot0 + dragonsecboot boot_package.fex + abootimg
# path the A133 uses. So tsp-s has its own assemble-sd.sh (extlinux/MBR) rather
# than reusing boards/tsp/genimage.cfg.
#
# Owned boot-chain partners (all source-built, tsp-vuo.1):
#   kernel : pocketforge-os/kernel-tsp-a523  (AvaotaSBC/linux 5.15.154 fork)
#   u-boot : pocketforge-os/u-boot-tsp-a523   (mainline v2025.10 + TG5050 port)
#   bl31   : jernejsk/arm-trusted-firmware@a523 (PLAT=sun55i_a523), embedded in SPL
# =============================================================================

BOARD=tsp-s
SOC=sun55iw3
SOC_FRIENDLY="Allwinner A523 (TG5050)"
KREL=5.15.154

# Serial console (vendor AW UART, registers ttyAS*). uart0 @ 0x02500000.
CONSOLE=ttyAS0
CONSOLE_BAUD=115200
EARLYCON="uart8250,mmio32,0x02500000"

# Kernel command line tail appended to extlinux `append`. The switch_root initrd
# resolves the rootfs by FS LABEL, so no root= is needed here; rootwait covers a
# slow MMC enumeration. cma for the (future) display engine / Cedar VE.
CMDLINE_EXTRA="loglevel=8 rootwait cma=96M"

# Kernel DTB. BRING-UP CRUTCH (tsp-vuo.1): the device's own stock DTB, recompiled
# (stock-pros-rebuilt.dtb). Replacing it with an owned source sun55i-t527-tg5050
# kernel DTS is tracked in tsp-vuo.7. The image build copies whatever
# A523_KERNEL_DTB points at into the FAT boot partition under this name.
DTB_NAME=sun55i-t527-tg5050.dtb

# SD layout (MBR, classic sunxi). SPL+U-Boot raw before the first partition.
SPL_OFFSET_KIB=8
IMAGE_NAME=pocketforge-tsp-s
