#!/bin/busybox sh
# =============================================================================
# PocketForge initrd /init  (TrimUI Smart Pro, Allwinner A133, vendor 4.9.191)
# -----------------------------------------------------------------------------
# Boot-critical. A wrong /init = no boot. Three things must be exactly right:
#   1. module load order: videobuf2-dma-contig -> pvrsrvkm -> dc_sunxi
#   2. rootfs found by GPT PARTLABEL (vendor U-Boot/kernel resolves by NAME,
#      never a hardcoded mmcblk index)
#   3. switch_root into the real rootfs (or, in M1.B mode, fall through to a
#      busybox shell instead)
#
# Observability (USER decision 2026-06-12; bd memory tsp-debug-observability-
# no-uart): every step is logged to BOTH the serial console AND a persistent
# file on the FAT "boot-resource" partition, so a failed boot is diagnosable
# by pulling the SD even when no UART is attached. Logging never blocks boot:
# if the log partition can't be mounted, we continue console-only.
#
# Mode select is data-driven, NOT a code fork: presence of the staged marker
# file /etc/pocketforge-m1b-mode (baked into M1.B-mode initrds only) switches
# the final handoff from switch_root to an interactive shell. Same /init
# source ships in M1.B and M1.C; M1.C simply omits the marker. (bd tsp-iuz.1.11)
#
# IMPORTANT module-name nuance: the videobuf2 DMA module's FILE is hyphenated
# on disk (videobuf2-dma-contig.ko) while its runtime/lsmod name is underscored
# (videobuf2_dma_contig). insmod-by-path uses the hyphen. (verified on blobs)
# =============================================================================

# Populate busybox applets into /bin (findfs, mount, insmod, switch_root, ...).
/bin/busybox --install -s /bin

# --- pseudo-filesystems -------------------------------------------------------
mount -t proc     proc     /proc
mount -t sysfs    sysfs    /sys
mount -t devtmpfs devtmpfs /dev

# --- on-SD boot log -----------------------------------------------------------
# Try to mount the FAT "boot-resource" partition rw at /pflog. The literal
# "boot" partition holds a raw Android boot.img (not a filesystem) — the FAT
# boot-resource partition is the writable, mountable log target.
#
# RESOLUTION BY FILESYSTEM LABEL, NOT GPT PARTLABEL: the Debian busybox
# `findfs` supports ONLY `LABEL=`/`UUID=` (no `PARTLABEL=`/`PARTUUID=`), and the
# `blkid` applet is not compiled in (verified against busybox-static 1.35.0).
# So the initrd resolves partitions by their FILESYSTEM volume label:
#   boot-resource FAT  -> volume label POCKETFORGE        (genimage: mkfs.vfat -n)
#   userdata      ext4 -> volume label POCKETFORGE_DATA   (genimage: ext4 label=)
# The KERNEL cmdline still uses `root=PARTLABEL=userdata` — the kernel's own
# partition parser DOES support PARTLABEL; only busybox doesn't. (The two keys
# must be kept consistent by the genimage config in tsp-iuz.1.7.)
PFLOG=""
mkdir -p /pflog
LOGDEV="$(findfs LABEL=POCKETFORGE 2>/dev/null)"
if [ -n "$LOGDEV" ] && mount -t vfat -o rw,flush "$LOGDEV" /pflog 2>/dev/null; then
    PFLOG=/pflog/bootlog.txt
    # Truncate at boot so the log reflects THIS boot, not an accreting history.
    : > "$PFLOG" 2>/dev/null || PFLOG=""
fi

# log <msg>: emit to console always; append to the SD log when available; sync
# after every line so even a truncated log names the last reached checkpoint
# (a hard hang before the next sync loses at most one step).
log() {
    echo "[pf-initrd] $*"
    if [ -n "$PFLOG" ]; then
        echo "[pf-initrd] $*" >> "$PFLOG" 2>/dev/null
        sync 2>/dev/null
    fi
}

# fail <msg>: log, then drop to an interactive busybox shell on the console so a
# failed boot is debuggable rather than a silent hang. sync first so the SD log
# captures the failure reason. The cmdline carries console=ttyS0,115200.
fail() {
    log "FAILURE: $*"
    log "dropping to busybox shell (console=ttyS0,115200)"
    sync 2>/dev/null
    exec /bin/sh
}

PF_INITRD_VERSION="$(cat /etc/pocketforge-initrd-version 2>/dev/null || echo dev)"
log "STAGE: banner — PocketForge initrd ${PF_INITRD_VERSION} booting"
if [ -n "$PFLOG" ]; then
    log "STAGE: on-SD log active at boot-resource:/bootlog.txt ($LOGDEV)"
else
    log "STAGE: on-SD log UNAVAILABLE (boot-resource not mountable) — console only"
fi

# =============================================================================
# SELF-FLASH RECOVERY  (dev images only; bd tsp-bcx.17)
# -----------------------------------------------------------------------------
# In-place whole-image self-flash for swap-free dev iteration. A host pushes a
# compressed image (.img.xz) to a RAW staging region in the UNALLOCATED TAIL of
# the SD (past the image; a normal flash never writes there), then writes a
# 512-byte flag record to a trailing sector and reboots. This branch — running
# entirely from the RAM initramfs with the SD UNMOUNTED — reads the staged blob
# from the high region and writes the decompressed whole image to the low region
# [0,img) of the SAME unmounted SD (non-overlapping), SHA-verifies, then reboots
# onto the new image. NO network, NO RAM staging, NOTHING from the SD mounted
# during the dd.
#
# Power-safe: the flag stays state=armed until a VERIFIED flash completes, so a
# power-loss mid-flash simply retries on the next boot (the destructive dd is
# idempotent). A `tries` cap stops a bootloop on a persistently bad blob.
#
# No hard-coded offsets: stage_lba / sizes / SHAs are computed by the host pusher
# (self-flash-device.sh) and read from the flag — /init only reads + validates +
# acts. Gated on /etc/pocketforge-selfflash (staged into DEV initrds only) so a
# prod image never honors a stray flag.  NOTE: if prod ever gains rootfs
# auto-expand, it MUST preserve this trailing state region (not implemented here).
#
# busybox/initramfs portability: explicit byte block sizes (no 4M suffix), no
# conv=fsync (uncertain in busybox dd) — durability via explicit `sync`.
# =============================================================================
SF_BS=4194304          # 4 MiB transfer block
SF_ALIGN_SECT=8192     # 4 MiB in 512-byte sectors (stage_lba alignment)

# Reconstruct + write the 512-byte flag record (NUL-padded full sector).
# args: state tries stage_lba xz_bytes xz_sha img_bytes img_sha card SD FLAG_LBA
selfflash_write_flag() {
    sf_st="$1"; sf_tr="$2"; sf_sl="$3"; sf_xb="$4"; sf_xs="$5"
    sf_ib="$6"; sf_is="$7"; sf_cs="$8"; sf_sd="$9"; sf_fl="${10}"
    {
        printf 'PF_FLAG=1\n'
        printf 'ver=1\n'
        printf 'state=%s\n'        "$sf_st"
        printf 'stage_lba=%s\n'    "$sf_sl"
        printf 'xz_bytes=%s\n'     "$sf_xb"
        printf 'xz_sha256=%s\n'    "$sf_xs"
        printf 'img_bytes=%s\n'    "$sf_ib"
        printf 'img_sha256=%s\n'   "$sf_is"
        printf 'tries=%s\n'        "$sf_tr"
        printf 'card_sectors=%s\n' "$sf_cs"
    } > /sf-flag.txt
    dd if=/dev/zero of=/sf-flag.bin bs=512 count=1 2>/dev/null
    dd if=/sf-flag.txt of=/sf-flag.bin conv=notrunc 2>/dev/null
    dd if=/sf-flag.bin of="$sf_sd" bs=512 seek="$sf_fl" count=1 2>/dev/null
    sync
}

# Perform recovery given the parsed flag text. Returns non-zero to fall through
# to a normal boot; reboots (does not return) on a successful flash.
selfflash_recover() {
    SD="$1"; NSECT="$2"; FLAG_LBA="$3"; FLAGTXT="$4"
    fget() { printf '%s\n' "$FLAGTXT" | sed -n "s/^$1=//p" | head -1; }
    state="$(fget state)";        stage_lba="$(fget stage_lba)"
    xz_bytes="$(fget xz_bytes)";  xz_sha="$(fget xz_sha256)"
    img_bytes="$(fget img_bytes)"; img_sha="$(fget img_sha256)"
    tries="$(fget tries)";        flag_card="$(fget card_sectors)"
    [ -n "$tries" ] || tries=0

    [ "$state" = "armed" ] || { log "selfflash: state=$state (not armed) — normal boot"; return 1; }
    log "selfflash: ARMED stage_lba=$stage_lba xz_bytes=$xz_bytes img_bytes=$img_bytes tries=$tries"

    for v in "$stage_lba" "$xz_bytes" "$img_bytes"; do
        case "$v" in ''|*[!0-9]*) log "selfflash: bad numeric field — abort to normal boot"; return 1;; esac
    done
    [ "$flag_card" = "$NSECT" ] || log "selfflash: WARN card_sectors flag=$flag_card live=$NSECT"

    xz_sectors=$(( (xz_bytes + 511) / 512 ))
    img_sectors=$(( (img_bytes + 511) / 512 ))
    [ $((stage_lba + xz_sectors)) -lt "$NSECT" ] || { log "selfflash: staged blob past card end — abort"; return 1; }
    [ "$stage_lba" -gt "$img_sectors" ]          || { log "selfflash: staged blob overlaps image region — abort"; return 1; }
    [ $(( stage_lba % SF_ALIGN_SECT )) -eq 0 ]   || { log "selfflash: stage_lba not 4MiB-aligned — abort"; return 1; }
    skip4m=$(( stage_lba / SF_ALIGN_SECT ))

    if [ "$tries" -ge 3 ]; then
        log "selfflash: tries=$tries >= 3 — giving up; marking failed, normal boot"
        selfflash_write_flag failed "$tries" "$stage_lba" "$xz_bytes" "$xz_sha" "$img_bytes" "$img_sha" "$NSECT" "$SD" "$FLAG_LBA"
        return 1
    fi
    # bump tries BEFORE the destructive write (raw flag sector; not in /pflog)
    selfflash_write_flag armed "$((tries+1))" "$stage_lba" "$xz_bytes" "$xz_sha" "$img_bytes" "$img_sha" "$NSECT" "$SD" "$FLAG_LBA"

    # release the SD — NOTHING from the SD may be mounted during the dd
    if [ -n "$PFLOG" ]; then sync; umount /pflog 2>/dev/null; PFLOG=""; fi
    if mount | grep -q mmcblk; then
        log "selfflash: FATAL — mmcblk still mounted, refusing to flash:"
        mount | grep mmcblk | while read -r l; do log "  $l"; done
        fail "selfflash: SD still mounted before dd"
    fi
    log "selfflash: SD unmounted; verified no mmcblk mounts"

    log "selfflash: verifying staged .img.xz sha256..."
    got_xz="$(dd if="$SD" bs="$SF_BS" skip="$skip4m" 2>/dev/null | head -c "$xz_bytes" | sha256sum | cut -d' ' -f1)"
    if [ "$got_xz" != "$xz_sha" ]; then
        log "selfflash: staged .xz SHA MISMATCH (got $got_xz want $xz_sha) — abort, retry next boot"
        return 1
    fi
    log "selfflash: staged .xz verified OK"

    # THE FLASH: read staged compressed from the high region, decompress, write
    # the whole image to the low region [0,img) of the SAME unmounted SD.
    log "selfflash: flashing — dd skip=$skip4m | unxz | dd of=$SD ..."
    if ! dd if="$SD" bs="$SF_BS" skip="$skip4m" 2>/dev/null | head -c "$xz_bytes" | unxz | dd of="$SD" bs="$SF_BS" 2>/dev/null; then
        log "selfflash: flash pipeline returned error — retry next boot"
        return 1
    fi
    sync
    log "selfflash: write complete; read-back verifying image sha256..."
    got_img="$(dd if="$SD" bs="$SF_BS" 2>/dev/null | head -c "$img_bytes" | sha256sum | cut -d' ' -f1)"
    if [ "$got_img" != "$img_sha" ]; then
        log "selfflash: image read-back SHA MISMATCH (got $got_img want $img_sha) — retry next boot"
        return 1
    fi
    log "selfflash: image verified OK — marking done, rebooting into new image"
    selfflash_write_flag done "$((tries+1))" "$stage_lba" "$xz_bytes" "$xz_sha" "$img_bytes" "$img_sha" "$NSECT" "$SD" "$FLAG_LBA"
    sync
    reboot -f
    return 0   # not reached
}

# --- self-flash gate (dev images only) ----------------------------------------
# Runs BEFORE the GPU insmods so recovery still works even if a bad image's GPU
# modules would fail (fail() drops to a shell). The SD enumerates asynchronously
# a few seconds into boot (mmc0 "new SDXC card" ~t=3.9s), AFTER /init starts — so
# wait for the rootfs partition to appear before reading the flag, rather than
# racing enumeration (the original rootfs mount below only wins that race because
# the GPU insmods burn enough time first).
if [ -f /etc/pocketforge-selfflash ]; then
    log "STAGE: self-flash gate — waiting for SD enumeration"
    SF_ROOTPART=""
    SF_WAIT=0
    while [ "$SF_WAIT" -lt 20 ]; do
        SF_ROOTPART="$(findfs LABEL=POCKETFORGE_DATA 2>/dev/null)"
        [ -n "$SF_ROOTPART" ] && [ -b "$SF_ROOTPART" ] && break
        SF_ROOTPART=""
        sleep 1
        SF_WAIT=$((SF_WAIT + 1))
    done
    if [ -n "$SF_ROOTPART" ]; then
        log "STAGE: self-flash gate — SD ready after ${SF_WAIT}s ($SF_ROOTPART)"
        # The SD block layer can still be settling its read path / final capacity
        # this early in boot (the original very-eager single probe raced: the flag
        # was armed but read as absent at the ~62 GB card-end LBA, with the full-OS
        # replay reading it fine). Re-resolve the SD by LABEL and read the flag in a
        # short retry loop; act the instant a valid flag appears. Non-destructive,
        # so retrying is safe. Logs each probe (tsp-bcx.17, ported from tsp-bcx.18).
        SF_FOUND=0; SF_TRY=0
        while [ "$SF_TRY" -lt 3 ]; do
            SF_ROOTPART="$(findfs LABEL=POCKETFORGE_DATA 2>/dev/null)"
            SF_SD="$(echo "$SF_ROOTPART" | sed 's/p[0-9]*$//')"   # /dev/mmcblk0p5 -> /dev/mmcblk0
            SF_DISK="$(basename "$SF_SD")"
            SF_PART="$(basename "$SF_ROOTPART")"                   # mmcblk0p5
            SF_NSECT="$(cat "/sys/block/${SF_DISK}/size" 2>/dev/null)"
            # Flag + staging live JUST PAST the rootfs partition (low LBA), NOT at
            # the card end: the A133 early-boot MMC does not service the ~62 GB
            # card-end LBA yet (reads return empty), though the full OS does. The
            # region adjacent to the (provably-readable) rootfs partition reads
            # fine. Both the gate and the host pusher derive flag_lba the same way
            # from the partition table: align_up(part_end + 1 MiB, 4 MiB).
            SF_PSTART="$(cat "/sys/class/block/${SF_PART}/start" 2>/dev/null)"
            SF_PSIZE="$(cat "/sys/class/block/${SF_PART}/size" 2>/dev/null)"
            if [ -n "$SF_PSTART" ] && [ -n "$SF_PSIZE" ] && [ -n "$SF_NSECT" ] && [ "$SF_NSECT" -gt 4096 ]; then
                SF_PEND=$(( SF_PSTART + SF_PSIZE ))
                SF_FLAG_LBA=$(( (SF_PEND + 2048 + 8191) / 8192 * 8192 ))
                SF_FLAGTXT="$(dd if="$SF_SD" bs=512 skip="$SF_FLAG_LBA" count=1 2>/dev/null | tr -d '\000' | tr -cd '[:print:]\n')"
                SF_HDR="$(printf '%s' "$SF_FLAGTXT" | head -c 11)"
                log "STAGE: self-flash flag probe try=${SF_TRY} sd=${SF_SD} pend=${SF_PEND} flag_lba=${SF_FLAG_LBA} hdr=[${SF_HDR}]"
                if printf '%s\n' "$SF_FLAGTXT" | grep -q '^PF_FLAG=1'; then
                    SF_FOUND=1
                    log "STAGE: self-flash flag present on ${SF_SD} (sector ${SF_FLAG_LBA})"
                    selfflash_recover "$SF_SD" "$SF_NSECT" "$SF_FLAG_LBA" "$SF_FLAGTXT" \
                        && log "selfflash: recovery returned without reboot — continuing normal boot" \
                        || log "selfflash: not flashing — continuing normal boot"
                    break
                fi
            fi
            SF_TRY=$((SF_TRY + 1)); sleep 2
        done
        [ "$SF_FOUND" = 1 ] || log "STAGE: self-flash gate — no armed flag after settle (${SF_TRY} probes) — normal boot"
    fi
fi

# --- PowerVR + buffer plumbing ------------------------------------------------
# Load order: vb2 (DMA buffers) -> pvrsrvkm (GPU KMD) -> dc_sunxi (DC bridge).
# Per-insmod trap: a silent skip past a vermagic mismatch would leave no
# breadcrumb, so each failure is fatal-with-a-message.
log "STAGE: insmod videobuf2-dma-contig"
insmod /lib/modules/videobuf2-dma-contig.ko || fail "insmod videobuf2-dma-contig failed (rc=$?)"

log "STAGE: insmod pvrsrvkm"
insmod /lib/modules/pvrsrvkm.ko || fail "insmod pvrsrvkm failed (rc=$?)"

log "STAGE: insmod dc_sunxi"
insmod /lib/modules/dc_sunxi.ko || fail "insmod dc_sunxi failed (rc=$?)"

log "STAGE: modules loaded"

# --- WiFi (NOT in the initrd) -------------------------------------------------
# PocketForge boots from a LOCAL SD rootfs, so WiFi is not needed before
# switch_root. The xradio triplet (xradio_mac -> xradio_core -> xradio_wlan)
# + xr829 firmware live in the rootfs and are brought up post-switch_root by
# wpa_supplicant + udhcpc (M1.C). Decision recorded in bd tsp-iuz.1.6.
#   insmod /lib/modules/xradio_mac.ko
#   insmod /lib/modules/xradio_core.ko
#   insmod /lib/modules/xradio_wlan.ko

# --- M1.B mode: fall through to a shell instead of switch_root ----------------
# Data-driven branch (NOT a separate /init). In M1.B-mode initrds the marker
# file is staged; in M1.C-onward initrds it is absent and we switch_root.
if [ -f /etc/pocketforge-m1b-mode ]; then
    log "STAGE: M1.B mode — falling through to busybox shell (no switch_root)"
    log "       (this is expected for the M1.B first-SD-boot milestone, G0)"
    # Disable the sunxi-wdt watchdog (CONFIG_SUNXI_WDOG_BOOTON=y auto-starts it
    # at driver probe with a 16-second timeout — without this, the device reboots
    # before the user can interact with the shell). Magic close: write 'V' then
    # close the fd.  Works because CONFIG_WATCHDOG_NOWAYOUT is not set (nowayout=0).
    if [ -c /dev/watchdog ]; then
        printf 'V' > /dev/watchdog
        log "STAGE: watchdog disabled (magic close)"
    else
        log "WARN: /dev/watchdog not found — watchdog may still be armed"
    fi
    sync 2>/dev/null
    exec /bin/sh
fi

# --- find + mount the rootfs by filesystem LABEL ------------------------------
# By LABEL (POCKETFORGE_DATA), not PARTLABEL — busybox findfs has no PARTLABEL
# support (see the on-SD-log block above). The kernel cmdline's
# root=PARTLABEL=userdata is the kernel's own resolution and is unaffected.
log "STAGE: locate rootfs by LABEL=POCKETFORGE_DATA"
ROOT="$(findfs LABEL=POCKETFORGE_DATA 2>/dev/null)"
[ -n "$ROOT" ] || fail "rootfs not found (LABEL=POCKETFORGE_DATA)"
log "STAGE: rootfs is $ROOT"

mkdir -p /newroot
log "STAGE: mount $ROOT -> /newroot (ext4)"
mount -t ext4 -o rw,noatime "$ROOT" /newroot || fail "mount $ROOT failed"

# --- watchdog keepalive before handoff -----------------------------------------
# The vendor kernel auto-starts sunxi-wdt at driver probe (CONFIG_SUNXI_WDOG_
# BOOTON=y, 16-second timeout, nowayout=0).  By this point ~3-5s of the 16s have
# elapsed.  Reset the counter so systemd has the full 16s window to start up,
# parse /etc/systemd/system.conf.d/watchdog.conf, and open /dev/watchdog itself.
# IMPORTANT: '\0' is a keepalive ping (resets the counter).  Do NOT write 'V' —
# that is the magic-close character which DISARMS the watchdog entirely.
if [ -c /dev/watchdog ]; then
    printf '\0' > /dev/watchdog
    log "STAGE: watchdog ping (counter reset for systemd handoff)"
else
    log "WARN: /dev/watchdog not found — watchdog ping skipped"
fi

# --- hand off to the real init ------------------------------------------------
# Unmount the log partition cleanly before handoff (switch_root will move /proc,
# /sys, /dev into /newroot; /pflog lives outside that and must be released).
if [ -n "$PFLOG" ]; then
    sync 2>/dev/null
    umount /pflog 2>/dev/null
fi

# Pre-switch_root verification: execv() after chroot returns ENOENT ("No such
# file or directory") when the ELF interpreter (PT_INTERP) is missing, not just
# when the binary itself is missing — and busybox prints the same misleading
# "can't execute" message for both cases.  Catch this before the point of no
# return (switch_root deletes the initrd).
log "STAGE: pre-switch_root verification"
for link in sbin lib bin; do
    target=$(readlink "/newroot/$link" 2>/dev/null)
    if [ -n "$target" ]; then
        log "  /newroot/$link -> $target"
    else
        log "  WARN: /newroot/$link is not a symlink"
    fi
done

# Use the fully-resolved path to sidestep the Debian usrmerge symlink chain:
#   /sbin/init -> (sbin->usr/sbin) -> /usr/sbin/init -> /lib/systemd/systemd
#   -> (lib->usr/lib) -> /usr/lib/systemd/systemd
# Every hop is a potential ENOENT if a symlink is broken.
INIT=/usr/lib/systemd/systemd
if [ ! -x "/newroot${INIT}" ]; then
    log "WARN: ${INIT} not found, trying /sbin/init"
    INIT=/sbin/init
fi
if [ ! -x "/newroot${INIT}" ]; then
    log "ERROR: no init binary found on rootfs"
    ls -la /newroot/usr/lib/systemd/ 2>&1 | while read line; do log "    $line"; done
    ls -la /newroot/sbin/ 2>&1 | while read line; do log "    $line"; done
    fail "init binary not found on rootfs"
fi

# Verify the dynamic linker exists — the OTHER cause of ENOENT from exec()
if [ ! -f "/newroot/usr/lib/aarch64-linux-gnu/ld-linux-aarch64.so.1" ]; then
    log "ERROR: arm64 dynamic linker missing"
    fail "dynamic linker (ld-linux-aarch64.so.1) not found"
fi
log "  init=${INIT}, dynamic linker OK"

log "STAGE: switch_root /newroot $INIT"
exec switch_root /newroot $INIT || fail "switch_root failed"
