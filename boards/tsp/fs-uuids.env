# PocketForge SD image — committed filesystem UUIDs
# Generated once; all builds use these for reproducible ext4/FAT.
# Changing a UUID here changes the image SHA-256.
#
# Used by: genimage.cfg, build-sd-image.sh
# Gate: G-reproducible (M1.E)

# ext4 userdata partition
USERDATA_FS_UUID=2935a3f6-bfce-5358-830d-9ea4d70edafc
USERDATA_HASH_SEED=bf1adbb8-0ad6-554c-a0b9-a1e10a34364b

# FAT boot-resource partition — FAT volume serial number (32-bit)
# genimage mkfs.vfat uses -i to set this
BOOTRES_VOLID=52A7C97E

# GPT disk UUID
DISK_UUID=0394742d-5609-5dca-9cc6-c86be0bebe96
